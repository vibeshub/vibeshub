# vibeshub — Azure deployment env vars
#
# Copy these onto your Container App's "Environment variables" tab.
# Replace every <placeholder>. Values without <...> can be used as-is.

# --- Required ---------------------------------------------------------------

# Postgres DSN. Must use the psycopg driver scheme and sslmode=require on Azure.
# Build from: admin user, admin password, the Flexible Server's hostname, db name.
VIBESHUB_DATABASE_URL=postgresql+psycopg://<pg-admin>:<pg-password>@<pg-name>.postgres.database.azure.com:5432/<db-name>?sslmode=require

# Blob container name. Its presence is what switches storage from local disk to Azure.
VIBESHUB_AZURE_BLOB_CONTAINER=traces

# Storage account blob endpoint. Auth uses DefaultAzureCredential (managed identity).
VIBESHUB_AZURE_STORAGE_ACCOUNT_URL=https://<storage-account>.blob.core.windows.net

# Client ID of the user-assigned managed identity bound to the Container App.
# Required so DefaultAzureCredential picks the right identity when more than one is bound.
AZURE_CLIENT_ID=<managed-identity-client-id>

# Public origin used to build trace_url responses from /api/ingest.
# After the first deploy, replace this with the actual Container App FQDN.
VIBESHUB_PUBLIC_BASE_URL=https://<app-name>.<region-suffix>.azurecontainerapps.io

# --- Optional --------------------------------------------------------------

# Alternative auth instead of VIBESHUB_AZURE_STORAGE_ACCOUNT_URL (account key
# or Azurite). Ignored if the account URL is set. Leave unset in production.
# VIBESHUB_AZURE_STORAGE_CONNECTION_STRING=

# Cap on transcript size in bytes. Default 52428800 (50 MB).
# VIBESHUB_MAX_TRACE_BYTES=52428800

# Override for tests; leave default in production.
# VIBESHUB_GITHUB_API_BASE=https://api.github.com
